# ============================================
# VSL360 Production Environment Variables
# Copy this file to .env.production and fill in the values.
# This file is gitignored — do NOT commit with real secrets.
#
# Local Docker: use .env.local.example → .env.local instead (see that file).
# ============================================

COMPOSE_ENV_FILE=.env.production

# -- PostgreSQL --
POSTGRES_USER=vsl360
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=vsl360

# -- Backend --
# DATABASE_URL is set automatically in docker-compose.yml from POSTGRES_* vars.
# Only set this if you need to override the auto-generated URL.
# DATABASE_URL=postgresql://vsl360:CHANGE_ME@db:5432/vsl360

JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_LONG_RANDOM_STRING
CORS_ORIGIN=https://admin.visitsrilanka360.com
CORS_ORIGINS=https://admin.visitsrilanka360.com,https://www.admin.visitsrilanka360.com
UPLOAD_DIR=/app/uploads
PORT=3000

# Optional: PDF/logo assets for documentGenerator (Docker: mount ./assets → /app/assets, see docker-compose.yml)
# DOCUMENT_LOGO_PATH=/app/assets/logo.png
# DOCUMENT_INVOICE_LOGO_PATH=/app/assets/logo-02.png
# DOCUMENT_THEME_PATH=/app/assets/theme.jpg
# DOCUMENT_LOGO_URL=https://your-cdn.example.com/logo.png
# DOCUMENT_INVOICE_LOGO_URL=https://your-cdn.example.com/logo-02.png

# -- Frontend (build-time) --
VITE_API_URL=https://api.admin.visitsrilanka360.com/api
