# ============================================
# Local Docker Compose (copy to .env.local)
# ============================================
#  cp .env.local.example .env.local
#  docker compose --env-file .env.local up -d --build
#
# COMPOSE_ENV_FILE must match this filename so services load the same file.
# ============================================

COMPOSE_ENV_FILE=.env.local

# -- PostgreSQL --
POSTGRES_USER=vsl360
POSTGRES_PASSWORD=localdev_change_me
POSTGRES_DB=vsl360

# -- Backend --
JWT_SECRET=localdev_change_me_use_openssl_rand_hex_32
JWT_REFRESH_SECRET=localdev_change_me_use_another_random_string
CORS_ORIGIN=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
UPLOAD_DIR=/app/uploads
PORT=3000
# Optional document branding overrides (use at least one path or URL to show logo in PDFs)
# DOCUMENT_LOGO_PATH=/app/uploads/assets/logo.png
# DOCUMENT_INVOICE_LOGO_PATH=/app/uploads/assets/logo-02.png
# DOCUMENT_THEME_PATH=/app/uploads/assets/theme.jpg
# DOCUMENT_LOGO_URL=https://your-cdn.example.com/logo.png
# DOCUMENT_INVOICE_LOGO_URL=https://your-cdn.example.com/logo-02.png

# -- Frontend (baked in at image build) --
VITE_API_URL=http://localhost:3000/api
