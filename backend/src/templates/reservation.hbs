<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { margin: 14mm 12mm; }
    :root {
      --ocean-blue: #204050;
      --tropical-green: #3d6b54;
      --sand-beige: #f0e0e0;
      --sunset-gold: #c08020;
      --paper: #f0f0f0;
      --ink: #1f2933;
      --muted: #6a7280;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Inter, 'Segoe UI', Arial, sans-serif; color: var(--ink); font-size: 12.5px; line-height: 1.5; background: var(--paper); }
    .page {
      border: 1px solid #dde2ea;
      border-radius: 10px;
      padding: 18px;
      background: #f5f6f8;
      min-height: calc(297mm - 28mm);
      display: flex;
      flex-direction: column;
    }
    .content { flex: 1; }
    .header { border-bottom: 3px solid var(--ocean-blue); padding-bottom: 14px; margin-bottom: 18px; display: flex; justify-content: space-between; align-items: center; }
    .logo { font-family: Inter, 'Segoe UI', Arial, sans-serif; font-size: 24px; font-weight: 700; color: var(--ocean-blue); }
    .logo span { color: var(--sunset-gold); }
    .title { font-family: Inter, 'Segoe UI', Arial, sans-serif; font-size: 24px; color: var(--ocean-blue); }
    .subtitle { color: var(--muted); font-size: 12px; text-align: right; }
    .section { margin-bottom: 16px; }
    .section h2 { font-family: Inter, 'Segoe UI', Arial, sans-serif; font-size: 16px; color: var(--ocean-blue); border-bottom: 1px solid #d9dce3; padding-bottom: 6px; margin-bottom: 10px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .field { margin-bottom: 6px; }
    .field .label { color: var(--muted); font-size: 10.5px; text-transform: uppercase; }
    .field .value { font-weight: 600; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; border: 1px solid #d6d9df; border-radius: 8px; overflow: hidden; }
    thead th { background: var(--ocean-blue); color: white; padding: 9px 10px; text-align: left; font-size: 12.5px; }
    tbody td { padding: 9px 10px; border-bottom: 1px solid #dfe3ea; font-size: 12.5px; }
    tbody tr:nth-child(even) { background: #f7f7f8; }
    .status { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .status-confirmed { background: #d7e9dc; color: #1e4f3a; }
    .status-pending { background: #f7ebcf; color: #8a621d; }
    .notes-box { background: #f7f0e3; border-left: 4px solid var(--sunset-gold); padding: 12px; border-radius: 6px; margin-top: 8px; }
    .intro { background: linear-gradient(90deg, #f7f0e3, #f0f0f0); border: 1px solid #e3d6bc; border-radius: 8px; padding: 10px 12px; margin-bottom: 12px; color: #3f3a32; }
    .footer { margin-top: auto; text-align: center; color: var(--muted); font-size: 11.5px; border-top: 1px solid #d9dce3; padding-top: 10px; }
    .tagline { color: var(--ocean-blue); font-weight: 600; }

    /* Safe adaptive mode: gentle density tweaks for longer reservations */
    body.compact { font-size: 12px; line-height: 1.42; }
    body.compact .page { padding: 15px; }
    body.compact .header { padding-bottom: 11px; margin-bottom: 14px; }
    body.compact .title { font-size: 22px; }
    body.compact .section { margin-bottom: 12px; }
    body.compact .section h2 { margin-bottom: 8px; padding-bottom: 5px; }
    body.compact .field { margin-bottom: 4px; }
    body.compact .notes-box { padding: 9px 10px; margin-top: 6px; }
    body.compact .intro { padding: 8px 10px; margin-bottom: 10px; font-size: 11.5px; }
    body.compact table { margin-top: 8px; }
    body.compact thead th { padding: 7px 8px; font-size: 12px; }
    body.compact tbody td { padding: 7px 8px; font-size: 12px; }
    body.compact .status { padding: 2px 8px; font-size: 10.5px; }
    body.compact .footer { margin-top: auto; padding-top: 8px; font-size: 11px; }
  </style>
</head>
<body class="{{layoutMode}}">
  <div class="page">
  <div class="content">
  <div class="header">
    <div class="logo">VSL <span>360</span></div>
    <div style="text-align:right;">
      <div class="title">LUXURY STAY RESERVATION</div>
      <div class="subtitle">Curated Travel Experiences</div>
    </div>
  </div>

  <div class="intro">
    Crafted for a seamless stay across Sri Lanka, with comfort, local character, and thoughtful details in every night of your journey.
  </div>

  <div class="section">
    <h2>Guest Information</h2>
    <div class="grid">
      <div class="field"><span class="label">Client Name</span><div class="value">{{client.name}}</div></div>
      <div class="field"><span class="label">Contact</span><div class="value">{{client.contactNumber}}</div></div>
      <div class="field"><span class="label">Travel Dates</span><div class="value">{{formatDate booking.arrivalDate}} — {{formatDate booking.departureDate}}</div></div>
      <div class="field"><span class="label">Booking ID</span><div class="value">{{booking.bookingId}}</div></div>
    </div>
  </div>

  <div class="section">
    <h2>Guest Count</h2>
    <div class="grid-3">
      <div class="field"><span class="label">Adults</span><div class="value">{{adults}}</div></div>
      <div class="field"><span class="label">Children</span><div class="value">{{children}}</div></div>
      <div class="field"><span class="label">Infants</span><div class="value">{{infants}}</div></div>
    </div>
  </div>

  {{#if booking.specialCelebrations}}
  <div class="section">
    <h2>Special Celebrations</h2>
    <div class="notes-box">{{booking.specialCelebrations}}</div>
  </div>
  {{/if}}

  <div class="section">
    <h2>Night-by-Night Hotel Plan</h2>
    <table>
      <thead>
        <tr>
          <th>Night</th>
          <th>Hotel</th>
          <th>Room Category</th>
          <th>Rooms</th>
          <th>Meal Plan</th>
          <th>Preference</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {{#each hotels}}
        <tr>
          <td>Night {{this.nightNumber}}</td>
          <td>{{this.hotelName}}</td>
          <td>{{this.roomCategory}}</td>
          <td>{{this.numberOfRooms}}</td>
          <td>{{this.mealPlan}}</td>
          <td>{{this.mealPreference}}</td>
          <td>
            {{#if (eq this.confirmationStatus "CONFIRMED")}}
              <span class="status status-confirmed">Confirmed</span>
            {{else}}
              <span class="status status-pending">Pending</span>
            {{/if}}
          </td>
        </tr>
        {{#if this.mobilityNotes}}
        <tr><td colspan="7" style="background:#fef3c7; font-size:12px;">Mobility: {{this.mobilityNotes}}</td></tr>
        {{/if}}
        {{#if this.reservationNotes}}
        <tr><td colspan="7" style="background:#f3f4f6; font-size:12px;">Notes: {{this.reservationNotes}}</td></tr>
        {{/if}}
        {{/each}}
      </tbody>
    </table>
  </div>
  </div>

  <div class="footer">
    <p>VSL 360 Tour Operations | Hotel Reservation Document</p>
    <p class="tagline">Experience Sri Lanka Completely</p>
  </div>
  </div>
</body>
</html>
