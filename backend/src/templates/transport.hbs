<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { margin: 9mm; }
    :root {
      --ocean-blue: #204050;
      --tropical-green: #3d6b54;
      --sand-beige: #f0e0e0;
      --sunset-gold: #c08020;
      --paper: #f0f0f0;
      --ink: #1f2933;
      --muted: #6a7280;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Mundial', 'Helvetica Neue', Arial, sans-serif; color: var(--ink); font-size: 12px; line-height: 1.4; background: var(--paper); }
    .page { border: 1px solid #dde2ea; border-radius: 10px; padding: 14px; background: #f5f6f8; }
    .header { border-bottom: 3px solid var(--ocean-blue); padding-bottom: 10px; margin-bottom: 12px; }
    .header h1 { font-family: 'Alegros', Georgia, serif; color: var(--ocean-blue); font-size: 21px; }
    .header .subtitle { color: var(--muted); font-size: 10.5px; text-transform: uppercase; letter-spacing: 1px; }
    .section { margin-bottom: 14px; }
    .section h2 { font-family: 'Alegros', Georgia, serif; font-size: 14px; color: var(--ocean-blue); border-bottom: 1px solid #d9dce3; padding-bottom: 5px; margin-bottom: 8px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .field { margin-bottom: 4px; }
    .field .label { color: var(--muted); font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.4px; }
    .field .value { font-weight: 600; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 11px; font-size: 11px; font-weight: 600; }
    .badge-yes { background: #d7e9dc; color: #1e4f3a; }
    .badge-no { background: #eceff3; color: #5f6875; }
    table { width: 100%; border-collapse: collapse; margin-top: 8px; border: 1px solid #d6d9df; border-radius: 8px; overflow: hidden; }
    thead th { background: var(--ocean-blue); color: white; padding: 7px 8px; text-align: left; font-size: 11.5px; }
    tbody td { padding: 7px 8px; border-bottom: 1px solid #dfe3ea; font-size: 11.5px; vertical-align: top; }
    tbody tr:nth-child(even) { background: #f7f7f8; }
    .notes-box { background: #f7f0e3; padding: 9px 10px; border-radius: 6px; border-left: 3px solid var(--sunset-gold); margin-top: 6px; }
    .intro { background: #f3f6f9; border: 1px solid #d7dfe8; border-radius: 8px; padding: 8px 10px; margin: 10px 0 12px; color: #384253; }
    .transfer-box { background: #f9fafc; border: 1px solid #dde2ea; border-radius: 8px; padding: 9px; }
    .transfer-title { font-family: 'Alegros', Georgia, serif; color: var(--ocean-blue); font-size: 13px; margin-bottom: 5px; }
    .footer { margin-top: 10px; text-align: center; color: var(--muted); font-size: 10.8px; border-top: 1px solid #d9dce3; padding-top: 8px; }
    .tagline { color: var(--ocean-blue); font-weight: 600; margin-top: 4px; }

    /* Adaptive layout tuning based on content density */
    body.compact { font-size: 11.5px; line-height: 1.34; }
    body.compact .page { padding: 12px; }
    body.compact .section { margin-bottom: 12px; }
    body.compact .section h2 { margin-bottom: 6px; }
    body.compact .grid { gap: 7px; }
    body.compact .field .label { font-size: 9px; }
    body.compact thead th { padding: 6px 7px; font-size: 11px; }
    body.compact tbody td { padding: 6px 7px; font-size: 11px; }
    body.compact .notes-box { padding: 7px 8px; }
    body.compact .intro { padding: 7px 8px; margin: 8px 0 8px; }

    body.ultra { font-size: 11px; line-height: 1.28; }
    body.ultra .page { padding: 10px; }
    body.ultra .header { margin-bottom: 8px; padding-bottom: 8px; }
    body.ultra .header h1 { font-size: 19px; }
    body.ultra .header .subtitle { font-size: 10px; }
    body.ultra .section { margin-bottom: 9px; }
    body.ultra .section h2 { font-size: 13px; margin-bottom: 5px; padding-bottom: 3px; }
    body.ultra .grid { gap: 6px; }
    body.ultra .field { margin-bottom: 2px; }
    body.ultra .field .label { font-size: 8.6px; }
    body.ultra .transfer-box { padding: 7px; }
    body.ultra .transfer-title { font-size: 12px; margin-bottom: 3px; }
    body.ultra thead th { padding: 5px 6px; font-size: 10.5px; }
    body.ultra tbody td { padding: 5px 6px; font-size: 10.5px; }
    body.ultra .notes-box { padding: 6px 7px; margin-top: 4px; }
    body.ultra .footer { margin-top: 7px; font-size: 10px; padding-top: 6px; }
  </style>
</head>
<body class="{{layoutMode}}">
  <div class="page">
  <div class="header">
    <h1>TRANSPORT DETAILS</h1>
    <span class="subtitle">Curated Travel Experiences | Internal Coordination</span>
  </div>

  {{#unless (eq layoutMode "ultra")}}
  <div class="intro">
    Movement plans designed for comfort, timing precision, and a smooth journey through each chapter of the island experience.
  </div>
  {{/unless}}

  <div class="section">
    <h2>Booking Information</h2>
    <div class="grid">
      <div class="field"><span class="label">Booking ID</span><div class="value">{{booking.bookingId}}</div></div>
      <div class="field"><span class="label">Client</span><div class="value">{{client.name}}</div></div>
      <div class="field"><span class="label">Travel Dates</span><div class="value">{{formatDate booking.arrivalDate}} — {{formatDate booking.departureDate}}</div></div>
      <div class="field"><span class="label">Duration</span><div class="value">{{booking.numberOfDays}} Days</div></div>
    </div>
  </div>

  <div class="section">
    <h2>Vehicle & Driver</h2>
    <div class="grid">
      <div class="field"><span class="label">Vehicle Model</span><div class="value">{{transport.vehicleModel}}</div></div>
      <div class="field"><span class="label">Driver</span><div class="value">{{transport.driverName}}</div></div>
      <div class="field"><span class="label">Driver Language</span><div class="value">{{transport.driverLanguage}}</div></div>
      <div class="field"><span class="label">Baby Seat</span><div class="value">{{#if transport.babySeatRequired}}<span class="badge badge-yes">Required</span>{{else}}<span class="badge badge-no">Not Required</span>{{/if}}</div></div>
    </div>
    {{#if transport.vehicleNotes}}
    <div class="notes-box">{{transport.vehicleNotes}}</div>
    {{/if}}
  </div>

  <div class="section">
    <h2>Transfer Windows</h2>
    <div class="grid">
      <div class="transfer-box">
        <div class="transfer-title">Arrival</div>
        <div class="field"><span class="label">Location</span><div class="value">{{transport.arrivalPickupLocation}}</div></div>
        <div class="field"><span class="label">Time</span><div class="value">{{transport.arrivalPickupTime}}</div></div>
        {{#if transport.arrivalPickupNotes}}
        <div class="notes-box">{{transport.arrivalPickupNotes}}</div>
        {{/if}}
      </div>
      <div class="transfer-box">
        <div class="transfer-title">Departure</div>
        <div class="field"><span class="label">Location</span><div class="value">{{transport.departureDropLocation}}</div></div>
        <div class="field"><span class="label">Time</span><div class="value">{{transport.departureDropTime}}</div></div>
        {{#if transport.departureDropNotes}}
        <div class="notes-box">{{transport.departureDropNotes}}</div>
        {{/if}}
      </div>
    </div>
  </div>

  {{#if transport.dayPlans.length}}
  <div class="section">
    <h2>Day-by-Day Transport Plan</h2>
    <table>
      <thead>
        <tr><th>Day</th><th>Description</th><th>Pickup</th><th>Drop</th><th>Notes</th></tr>
      </thead>
      <tbody>
        {{#each transport.dayPlans}}
        <tr>
          <td>Day {{this.dayNumber}}</td>
          <td>{{this.description}}</td>
          <td>{{this.pickupLocation}}{{#if this.pickupTime}} ({{this.pickupTime}}){{/if}}</td>
          <td>{{this.dropLocation}}</td>
          <td>{{this.notes}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{#if transport.internalNotes}}
  <div class="section">
    <h2>Internal Notes</h2>
    <div class="notes-box">{{transport.internalNotes}}</div>
  </div>
  {{/if}}

  <div class="footer">
    <p>VSL 360 — Internal Transport Document</p>
    <p class="tagline">Experience Sri Lanka Completely</p>
  </div>
  </div>
</body>
</html>
