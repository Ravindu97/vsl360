<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { margin: 12mm 10mm; }
    :root {
      --ocean-blue: #204050;
      --tropical-green: #3d6b54;
      --sand-beige: #f0e0e0;
      --sunset-gold: #c08020;
      --paper: #f0f0f0;
      --ink: #1f2933;
      --muted: #687283;
      --bar: #3a2d2c;
      --line: #cfd5dd;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Mundial', 'Helvetica Neue', Arial, sans-serif;
      color: var(--ink);
      font-size: 12.5px;
      line-height: 1.5;
      background: var(--paper);
    }

    .cover-page {
      border: 1px solid #dde2ea;
      border-radius: 10px;
      overflow: hidden;
      height: calc(297mm - 28mm);
      background: #f5f6f8;
      background-image: url('{{#if coverTemplateImage}}{{coverTemplateImage}}{{else}}{{themeImage}}{{/if}}');
      background-size: cover;
      background-position: center top;
      page-break-inside: avoid;
      position: relative;
    }
    .cover-overlay {
      height: calc(297mm - 28mm);
      background: linear-gradient(180deg, rgba(248, 249, 251, 0.08) 0%, rgba(248, 249, 251, 0.78) 34%, rgba(248, 249, 251, 0.95) 100%);
      padding: 0 24px 24px;
      display: flex;
      flex-direction: column;
    }
    .brand-emblem {
      width: 238px;
      height: 130px;
      margin: 0 auto 6px;
      background: #f8f9fb;
      border-radius: 0 0 140px 140px;
      border: 1px solid rgba(209, 177, 120, 0.45);
      border-top: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 20px rgba(34, 46, 60, 0.06);
    }
    .brand-emblem img {
      max-width: 162px;
      max-height: 96px;
      object-fit: contain;
    }
    .cover-title {
      text-align: center;
      margin: 10px 0 10px;
      font-family: 'Alegros', Georgia, serif;
      font-size: 50px;
      letter-spacing: 0.4px;
      color: #3a2f2d;
      text-transform: uppercase;
      line-height: 1;
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.5);
    }
    .cover-meta {
      margin: 0 auto 14px;
      padding: 7px 14px;
      border: 1px solid rgba(115, 104, 94, 0.18);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.56);
      color: #534845;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.3px;
      text-align: center;
      backdrop-filter: blur(4px);
    }
    .logo {
      font-family: 'Alegros', Georgia, serif;
      font-size: 32px;
      font-weight: 700;
      color: #1f3f55;
      letter-spacing: 0.4px;
    }
    .logo span { color: #c08020; }

    .cover-section { margin-bottom: 12px; }
    .cover-section-title {
      background: var(--bar);
      color: #ffffff;
      font-size: 17px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      padding: 7px 11px;
    }

    .overview-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 18px;
      background: rgba(250, 250, 250, 0.82);
      border: 1px solid #d4d8dd;
      border-top: 0;
      padding: 10px 11px;
    }
    .overview-column { display: grid; gap: 6px; }
    .cover-panel {
      background: rgba(250, 250, 250, 0.82);
      border: 1px solid #d4d8dd;
      border-top: 0;
      padding: 10px 11px;
    }
    .cover-panel-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 18px;
    }
    .flight-table {
      width: 100%;
      border-collapse: collapse;
      border: 1px solid #c4c9d1;
      border-top: 0;
      background: rgba(250, 250, 250, 0.86);
      font-size: 12px;
    }
    .flight-table th,
    .flight-table td {
      border: 1px solid #aeb5bf;
      padding: 7px 8px;
      text-align: center;
      vertical-align: middle;
    }
    .flight-table th {
      background: #ece7dd;
      font-weight: 700;
      color: #302b2b;
    }
    .kv {
      display: grid;
      grid-template-columns: 122px 12px 1fr;
      align-items: baseline;
      gap: 2px;
      font-size: 12px;
    }
    .kv .k { font-weight: 700; color: #362f2f; }
    .kv .sep { text-align: center; color: #4f4949; }
    .kv .v { color: #342f2f; }

    .accommodation-table {
      width: 100%;
      border-collapse: collapse;
      border: 1px solid #d1d6de;
      border-top: 0;
      background: rgba(250, 250, 250, 0.86);
      font-size: 12px;
    }
    .accommodation-table td {
      border: 1px solid #b8bec8;
      padding: 8px 9px;
      vertical-align: middle;
    }
    .accommodation-table td.night {
      width: 110px;
      font-weight: 700;
      text-align: center;
      background: #d9ceba;
      color: #342f2f;
    }

    .page {
      border: 1px solid #dde2ea;
      border-radius: 10px;
      background: #f5f6f8;
      min-height: calc(297mm - 24mm);
      overflow: hidden;
      margin-top: 8mm;
      page-break-inside: avoid;
    }
    .daily-top-image {
      height: 120px;
      background-size: cover;
      background-position: center center;
      position: relative;
      border-bottom: 1px solid #cdd3db;
    }
    .daily-logo-badge {
      width: 230px;
      height: 108px;
      border-radius: 0 0 130px 130px;
      background: rgba(248, 249, 251, 0.95);
      border: 1px solid rgba(209, 177, 120, 0.45);
      border-top: 0;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .daily-logo-badge img {
      max-width: 148px;
      max-height: 84px;
      object-fit: contain;
    }
    .daily-content { padding: 14px 16px 16px; }
    .daily-title {
      background: var(--bar);
      color: #ffffff;
      font-size: 18px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      padding: 6px 10px;
      margin-bottom: 10px;
    }
    .day-hero {
      display: grid;
      grid-template-columns: 250px 1fr;
      border: 1px solid #be8f34;
      background: linear-gradient(90deg, #e7d6b5 0%, #efe9df 100%);
      margin-bottom: 10px;
    }
    .day-place-image {
      min-height: 170px;
      background: linear-gradient(150deg, #3a8cb8, #1f6e9c);
      color: #ffffff;
      padding: 14px 10px;
      position: relative;
      border-right: 1px solid #be8f34;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }
    .day-place-image .day-index {
      position: absolute;
      right: 10px;
      top: 8px;
      font-size: 52px;
      font-weight: 800;
      line-height: 1;
      opacity: 0.9;
    }
    .day-place-image .day-tag {
      position: absolute;
      right: 62px;
      top: 12px;
      transform: rotate(-90deg);
      transform-origin: top right;
      font-size: 24px;
      font-weight: 700;
      letter-spacing: 1px;
    }
    .day-place-image .place-label {
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.7px;
    }
    .day-summary {
      padding: 10px 12px;
      color: #312d2c;
      font-size: 13px;
      line-height: 1.38;
    }
    .day-summary h3 {
      font-size: 16px;
      line-height: 1.3;
      margin-bottom: 6px;
      color: #322d2d;
    }
    .day-summary .lead { font-weight: 700; margin-bottom: 4px; }
    .day-summary ul { margin: 4px 0 0 18px; }
    .day-summary li { margin: 2px 0; }
    .activity-table {
      width: 100%;
      border-collapse: collapse;
      border: 1px solid #8c8f94;
      background: #f7f7f8;
      font-size: 12px;
    }
    .activity-table td {
      border: 1px solid #8c8f94;
      padding: 8px 8px;
      vertical-align: top;
    }
    .activity-table td.activity-name {
      width: 190px;
      font-size: 15px;
      font-weight: 700;
      color: #332f2f;
      line-height: 1.25;
    }
    .activity-table td.activity-desc {
      font-size: 12px;
      line-height: 1.35;
      color: #2f2f31;
    }
    .planner-notes {
      margin-top: 9px;
      border-left: 3px solid #be8f34;
      background: #f6f2ea;
      padding: 8px 10px;
      font-size: 12px;
      color: #413b39;
    }

    body.compact { font-size: 12px; line-height: 1.42; }
    body.compact .cover-title { font-size: 44px; margin: 8px 0 8px; }
    body.compact .cover-meta { margin-bottom: 12px; font-size: 11.5px; padding: 6px 12px; }
    body.compact .brand-emblem { width: 224px; height: 122px; }
    body.compact .cover-section-title { font-size: 16px; }
    body.compact .overview-grid { gap: 10px 14px; padding: 9px 10px; }
    body.compact .cover-panel { padding: 9px 10px; }
    body.compact .cover-panel-grid { gap: 10px 14px; }
    body.compact .kv { grid-template-columns: 112px 10px 1fr; font-size: 11.5px; }
    body.compact .accommodation-table { font-size: 12px; }
    body.compact .accommodation-table td { padding: 6px 7px; }

    body.compact .daily-top-image { height: 108px; }
    body.compact .daily-logo-badge { width: 210px; height: 100px; }
    body.compact .daily-title { font-size: 17px; }
    body.compact .day-hero { grid-template-columns: 220px 1fr; }
    body.compact .day-place-image { min-height: 154px; }
    body.compact .day-place-image .day-index { font-size: 48px; }
    body.compact .day-place-image .day-tag { right: 56px; font-size: 21px; }
    body.compact .activity-table td.activity-name { width: 170px; font-size: 14px; }
  </style>
</head>
<body class="{{layoutMode}}">
  <div class="cover-page">
    <div class="cover-overlay">
      <div class="brand-emblem">
        {{#if brandLogoImage}}
        <img src="{{brandLogoImage}}" alt="VSL 360">
        {{else}}
        <div class="logo">VSL <span>360</span></div>
        {{/if}}
      </div>

      <h1 class="cover-title">Travel Itinerary</h1>

      <div class="cover-meta">
        {{formatDate booking.arrivalDate}} to {{formatDate booking.departureDate}} | {{booking.numberOfDays}} Days | {{totalGuests}} Guests
      </div>

      <div class="cover-section">
        <div class="cover-section-title">Trip Overview</div>
        <div class="overview-grid">
          <div class="overview-column">
            <div class="kv"><span class="k">Group Name</span><span class="sep">:</span><span class="v">{{client.name}}</span></div>
            <div class="kv"><span class="k">No Of Pax</span><span class="sep">:</span><span class="v">{{guestBreakdown adults children infants}}</span></div>
            <div class="kv"><span class="k">No of Rooms</span><span class="sep">:</span><span class="v">{{roomSummary hotels}}</span></div>
            <div class="kv"><span class="k">Meal Plan</span><span class="sep">:</span><span class="v">{{mealPlanSummary hotels}}</span></div>
          </div>
          <div class="overview-column">
            <div class="kv"><span class="k">Travel Dates</span><span class="sep">:</span><span class="v">{{formatDate booking.arrivalDate}} to {{formatDate booking.departureDate}}</span></div>
            <div class="kv"><span class="k">Pick Up Point</span><span class="sep">:</span><span class="v">{{#if transport.arrivalPickupLocation}}{{transport.arrivalPickupLocation}}{{else}}Airport Arrival Lobby{{/if}}</span></div>
            <div class="kv"><span class="k">Transfer Type</span><span class="sep">:</span><span class="v">{{#if transport.vehicleModel}}{{transport.vehicleModel}}{{else}}Private Transfer{{/if}}</span></div>
            <div class="kv"><span class="k">Reservation No</span><span class="sep">:</span><span class="v">{{booking.bookingId}}</span></div>
          </div>
        </div>
      </div>

      <div class="cover-section">
        <div class="cover-section-title">Flight Details</div>
        <table class="flight-table">
          <thead>
            <tr>
              <th>Arrival</th>
              <th>Flight</th>
              <th>Time</th>
              <th>Departure</th>
              <th>Flight</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{{formatDate booking.arrivalDate}}</td>
              <td>As Per Ticket</td>
              <td>{{booking.arrivalTime}}</td>
              <td>{{formatDate booking.departureDate}}</td>
              <td>As Per Ticket</td>
              <td>{{booking.departureTime}}</td>
            </tr>
          </tbody>
        </table>
      </div>

      {{#if transport}}
      <div class="cover-section">
        <div class="cover-section-title">Transport Details</div>
        <div class="cover-panel">
          <div class="cover-panel-grid">
            <div class="overview-column">
              <div class="kv"><span class="k">Arrival Point</span><span class="sep">:</span><span class="v">{{#if transport.arrivalPickupLocation}}{{transport.arrivalPickupLocation}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Arrival Time</span><span class="sep">:</span><span class="v">{{#if transport.arrivalPickupTime}}{{transport.arrivalPickupTime}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Driver</span><span class="sep">:</span><span class="v">{{#if transport.driverName}}{{transport.driverName}}{{else}}Assigned Closer To Arrival{{/if}}</span></div>
            </div>
            <div class="overview-column">
              <div class="kv"><span class="k">Departure Point</span><span class="sep">:</span><span class="v">{{#if transport.departureDropLocation}}{{transport.departureDropLocation}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Departure Time</span><span class="sep">:</span><span class="v">{{#if transport.departureDropTime}}{{transport.departureDropTime}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Vehicle</span><span class="sep">:</span><span class="v">{{#if transport.vehicleModel}}{{transport.vehicleModel}}{{else}}Private Transfer{{/if}}</span></div>
            </div>
          </div>
        </div>
      </div>
      {{/if}}

      <div class="cover-section">
        <div class="cover-section-title">Accommodation (On {{#if hotels.0.mealPlan}}{{titleCase hotels.0.mealPlan}}{{else}}Confirmed Basis{{/if}})</div>
        <table class="accommodation-table">
          <tbody>
            {{#each hotels}}
            <tr>
              <td class="night">{{this.nightNumber}} Night</td>
              <td>{{this.hotelName}}</td>
              <td>{{this.roomCategory}}</td>
              <td>{{#if this.mealPlan}}{{titleCase this.mealPlan}}{{else}}As Confirmed{{/if}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  {{#each days}}
  <div class="page">
    <div class="daily-top-image" style="background-image: url('{{#if ../coverTemplateImage}}{{../coverTemplateImage}}{{else}}{{../themeImage}}{{/if}}');">
      <div class="daily-logo-badge">
        {{#if ../brandLogoImage}}
        <img src="{{../brandLogoImage}}" alt="VSL 360">
        {{else}}
        <div class="logo">VSL <span>360</span></div>
        {{/if}}
      </div>
    </div>

    <div class="daily-content">
      <div class="daily-title">Daily Itinerary</div>

      <div class="day-hero">
        <div class="day-place-image">
          <div class="day-tag">DAY</div>
          <div class="day-index">{{this.dayNumber}}</div>
          <div class="place-label">{{#if this.itinerary.destinationName}}{{this.itinerary.destinationName}}{{else}}Destination Image Placeholder{{/if}}</div>
        </div>
        <div class="day-summary">
          <h3>{{#if this.itinerary.destinationName}}{{this.itinerary.destinationName}}{{else}}Sri Lanka Journey Highlights{{/if}}</h3>
          <p class="lead">{{#if this.transport.description}}{{this.transport.description}}{{else}}Your day is curated around memorable experiences and smooth transitions.{{/if}}</p>
          {{#if this.itinerary.activities.length}}
          <ul>
            {{#each this.itinerary.activities}}
            <li>{{this.title}}</li>
            {{/each}}
          </ul>
          {{/if}}
          {{#if this.hotel}}
          <p style="margin-top: 6px;">Stay at {{this.hotel.hotelName}}</p>
          {{/if}}
        </div>
      </div>

      <table class="activity-table">
        <tbody>
          {{#if this.itinerary.activities.length}}
            {{#each this.itinerary.activities}}
            <tr>
              <td class="activity-name">{{this.title}}<br>({{this.duration}})</td>
              <td class="activity-desc">{{this.description}}</td>
            </tr>
            {{/each}}
          {{else}}
            <tr>
              <td class="activity-name">No activities selected</td>
              <td class="activity-desc">Use the Itinerary Plan tab to select morning, afternoon, and evening activities for this day.</td>
            </tr>
          {{/if}}
        </tbody>
      </table>

      {{#if this.itinerary.notes}}
      <div class="planner-notes">
        <strong>Planner Notes:</strong> {{this.itinerary.notes}}
      </div>
      {{/if}}
    </div>
  </div>
  {{/each}}
</body>
</html>
