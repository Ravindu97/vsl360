<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { margin: 12mm 10mm; }
    :root {
      --ocean-blue: #204050;
      --tropical-green: #3d6b54;
      --sand-beige: #f0e0e0;
      --sunset-gold: #c08020;
      --paper: #f0f0f0;
      --ink: #1f2933;
      --muted: #687283;
      --bar: #3a2d2c;
      --line: #cfd5dd;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Mundial', 'Helvetica Neue', Arial, sans-serif;
      color: var(--ink);
      font-size: 12.5px;
      line-height: 1.5;
      background: var(--paper);
    }

    .cover-page {
      border: 1px solid #dde2ea;
      border-radius: 10px;
      overflow: hidden;
      height: calc(297mm - 28mm);
      background: #f5f6f8;
      background-image: url('{{#if coverTemplateImage}}{{coverTemplateImage}}{{else}}{{themeImage}}{{/if}}');
      background-size: cover;
      background-position: center top;
      page-break-inside: avoid;
      position: relative;
    }
    .cover-overlay {
      height: calc(297mm - 28mm);
      background: linear-gradient(180deg, rgba(248, 249, 251, 0.08) 0%, rgba(248, 249, 251, 0.78) 34%, rgba(248, 249, 251, 0.95) 100%);
      padding: 0 24px 24px;
      display: flex;
      flex-direction: column;
    }
    .brand-emblem {
      width: 238px;
      height: 130px;
      margin: 0 auto 6px;
      background: #f8f9fb;
      border-radius: 0 0 140px 140px;
      border: 1px solid rgba(209, 177, 120, 0.45);
      border-top: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 20px rgba(34, 46, 60, 0.06);
    }
    .brand-emblem img {
      max-width: 162px;
      max-height: 96px;
      object-fit: contain;
    }
    .cover-title {
      text-align: center;
      margin: 10px 0 10px;
      font-family: 'Alegros', Georgia, serif;
      font-size: 50px;
      letter-spacing: 0.4px;
      color: #3a2f2d;
      text-transform: uppercase;
      line-height: 1;
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.5);
    }
    .cover-meta {
      margin: 0 auto 14px;
      padding: 7px 14px;
      border: 1px solid rgba(115, 104, 94, 0.18);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.56);
      color: #534845;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.3px;
      text-align: center;
      backdrop-filter: blur(4px);
    }

    .cover-section { margin-bottom: 12px; }
    .cover-section-title {
      background: var(--bar);
      color: #ffffff;
      font-size: 17px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      padding: 7px 11px;
    }

    .overview-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 18px;
      background: rgba(250, 250, 250, 0.82);
      border: 1px solid #d4d8dd;
      border-top: 0;
      padding: 10px 11px;
    }
    .overview-column { display: grid; gap: 6px; }
    .cover-panel {
      background: rgba(250, 250, 250, 0.82);
      border: 1px solid #d4d8dd;
      border-top: 0;
      padding: 10px 11px;
    }
    .cover-panel-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 18px;
    }
    .kv {
      display: grid;
      grid-template-columns: 122px 12px 1fr;
      align-items: baseline;
      gap: 2px;
      font-size: 12px;
    }
    .kv .k { font-weight: 700; color: #362f2f; }
    .kv .sep { text-align: center; color: #4f4949; }
    .kv .v { color: #342f2f; }

    .accommodation-table {
      width: 100%;
      border-collapse: collapse;
      border: 1px solid #d1d6de;
      border-top: 0;
      background: rgba(250, 250, 250, 0.86);
      font-size: 12px;
    }
    .accommodation-table td {
      border: 1px solid #b8bec8;
      padding: 8px 9px;
      vertical-align: middle;
    }
    .accommodation-table td.night {
      width: 110px;
      font-weight: 700;
      text-align: center;
      background: #d9ceba;
      color: #342f2f;
    }

    .page {
      border: 1px solid #dde2ea;
      border-radius: 10px;
      padding: 16px;
      background: #f5f6f8;
      min-height: calc(297mm - 24mm);
      display: flex;
      flex-direction: column;
    }
    .content { flex: 1; }
    .header { text-align: center; border-bottom: 3px solid var(--ocean-blue); padding-bottom: 14px; margin-bottom: 16px; }
    .logo { font-family: 'Alegros', Georgia, serif; font-size: 30px; font-weight: 700; color: var(--ocean-blue); }
    .logo span { color: var(--sunset-gold); }
    .header h1 { font-family: 'Alegros', Georgia, serif; font-size: 24px; color: var(--ocean-blue); margin-top: 6px; }
    .header .subtitle { color: var(--muted); margin-top: 4px; }
    .welcome { background: linear-gradient(120deg, #204050, #3d6b54); color: #fff; padding: 14px; border-radius: 10px; margin-bottom: 14px; }
    .welcome h2 { font-family: 'Alegros', Georgia, serif; font-size: 20px; margin-bottom: 8px; }
    .pillar { border: 1px solid #d8dde6; border-radius: 10px; margin-bottom: 10px; overflow: hidden; page-break-inside: avoid; }
    .pillar h3 { font-family: 'Alegros', Georgia, serif; background: #f3f6f9; color: var(--ocean-blue); padding: 9px 12px; border-bottom: 1px solid #d8dde6; }
    .pillar-body { padding: 10px 12px; }
    .day-card { border: 1px solid #d8dde6; border-radius: 10px; margin-bottom: 10px; overflow: hidden; page-break-inside: avoid; }
    .day-header { background: var(--ocean-blue); color: white; padding: 9px 12px; font-weight: 700; font-size: 15px; }
    .day-body { padding: 12px; }
    .day-body .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .detail { margin-bottom: 8px; }
    .detail .label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
    .detail .value { font-weight: 600; color: #111827; }
    .notes-section { background: #f7f0e3; border-left: 4px solid var(--sunset-gold); padding: 11px; border-radius: 8px; margin-top: 10px; page-break-inside: avoid; }
    .notes-section h3 { font-family: 'Alegros', Georgia, serif; font-size: 15px; color: var(--ocean-blue); margin-bottom: 8px; }
    .cta-list { margin-top: 14px; list-style: none; padding-left: 0; }
    .cta-list li {
      position: relative;
      margin-bottom: 14px;
      padding-left: 28px;
      color: #3f4d61;
      font-size: 14px;
      line-height: 1.45;
      text-align: left;
    }
    .cta-list li:last-child { margin-bottom: 0; }
    .cta-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.56em;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #42546b;
    }
    .footer { margin-top: auto; text-align: center; padding: 12px; background: #f4f6f8; border: 1px solid #d8dde6; border-radius: 10px; page-break-inside: avoid; }
    .footer p { color: #5f6875; font-size: 13px; }
    .footer .brand { font-family: 'Alegros', Georgia, serif; font-size: 18px; font-weight: 700; color: var(--ocean-blue); margin-bottom: 4px; }

    body.compact { font-size: 12px; line-height: 1.42; }
    body.compact .cover-title { font-size: 44px; margin: 8px 0 8px; }
    body.compact .cover-meta { margin-bottom: 12px; font-size: 11.5px; padding: 6px 12px; }
    body.compact .brand-emblem { width: 224px; height: 122px; }
    body.compact .cover-section-title { font-size: 16px; }
    body.compact .overview-grid { gap: 10px 14px; padding: 9px 10px; }
    body.compact .cover-panel { padding: 9px 10px; }
    body.compact .cover-panel-grid { gap: 10px 14px; }
    body.compact .kv { grid-template-columns: 112px 10px 1fr; font-size: 11.5px; }
    body.compact .accommodation-table { font-size: 12px; }
    body.compact .accommodation-table td { padding: 6px 7px; }

    body.compact .page { padding: 14px; }
    body.compact .header { padding-bottom: 11px; margin-bottom: 12px; }
    body.compact .logo { font-size: 27px; }
    body.compact .header h1 { font-size: 22px; }
    body.compact .welcome { padding: 11px; margin-bottom: 11px; }
    body.compact .welcome h2 { font-size: 18px; margin-bottom: 6px; }
    body.compact .pillar { margin-bottom: 8px; }
    body.compact .pillar h3 { padding: 8px 10px; }
    body.compact .pillar-body { padding: 8px 10px; }
    body.compact .day-card { margin-bottom: 8px; }
    body.compact .day-header { padding: 8px 10px; font-size: 14px; }
    body.compact .day-body { padding: 10px; }
    body.compact .day-body .grid { gap: 10px; }
    body.compact .detail { margin-bottom: 6px; }
    body.compact .notes-section { padding: 9px; margin-top: 8px; }
    body.compact .notes-section h3 { font-size: 14px; margin-bottom: 6px; }
    body.compact .footer { margin-top: auto; padding: 10px; }
    body.compact .cta-list { margin-top: 10px; }
    body.compact .cta-list li { margin-bottom: 10px; padding-left: 24px; font-size: 13px; }
    body.compact .cta-list li::before { width: 7px; height: 7px; top: 0.6em; }
  </style>
</head>
<body class="{{layoutMode}}">
  <div class="cover-page">
    <div class="cover-overlay">
      <div class="brand-emblem">
        {{#if brandLogoImage}}
        <img src="{{brandLogoImage}}" alt="VSL 360">
        {{else}}
        <div class="logo">VSL <span>360</span></div>
        {{/if}}
      </div>

      <h1 class="cover-title">Travel Itinerary</h1>

      <div class="cover-meta">
        {{formatDate booking.arrivalDate}} to {{formatDate booking.departureDate}} | {{booking.numberOfDays}} Days | {{totalGuests}} Guests
      </div>

      <div class="cover-section">
        <div class="cover-section-title">Trip Overview</div>
        <div class="overview-grid">
          <div class="overview-column">
            <div class="kv"><span class="k">Lead Guest</span><span class="sep">:</span><span class="v">{{client.name}}</span></div>
            <div class="kv"><span class="k">Duration</span><span class="sep">:</span><span class="v">{{booking.numberOfDays}} Days</span></div>
            <div class="kv"><span class="k">Guest Count</span><span class="sep">:</span><span class="v">{{totalGuests}} Guests</span></div>
            <div class="kv"><span class="k">Stay Plan</span><span class="sep">:</span><span class="v">{{roomNights}} Night Stops</span></div>
          </div>
          <div class="overview-column">
            <div class="kv"><span class="k">Travel Dates</span><span class="sep">:</span><span class="v">{{formatDate booking.arrivalDate}} to {{formatDate booking.departureDate}}</span></div>
            <div class="kv"><span class="k">Booking Ref</span><span class="sep">:</span><span class="v">{{booking.bookingId}}</span></div>
            <div class="kv"><span class="k">Meal Plan</span><span class="sep">:</span><span class="v">{{#if hotels.0.mealPlan}}{{titleCase hotels.0.mealPlan}}{{else}}As Confirmed{{/if}}</span></div>
            <div class="kv"><span class="k">Document Type</span><span class="sep">:</span><span class="v">Private Journey Itinerary</span></div>
          </div>
        </div>
      </div>

      {{#if transport}}
      <div class="cover-section">
        <div class="cover-section-title">Transport Details</div>
        <div class="cover-panel">
          <div class="cover-panel-grid">
            <div class="overview-column">
              <div class="kv"><span class="k">Arrival Point</span><span class="sep">:</span><span class="v">{{#if transport.arrivalPickupLocation}}{{transport.arrivalPickupLocation}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Arrival Time</span><span class="sep">:</span><span class="v">{{#if transport.arrivalPickupTime}}{{transport.arrivalPickupTime}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Driver</span><span class="sep">:</span><span class="v">{{#if transport.driverName}}{{transport.driverName}}{{else}}Assigned Closer To Arrival{{/if}}</span></div>
            </div>
            <div class="overview-column">
              <div class="kv"><span class="k">Departure Point</span><span class="sep">:</span><span class="v">{{#if transport.departureDropLocation}}{{transport.departureDropLocation}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Departure Time</span><span class="sep">:</span><span class="v">{{#if transport.departureDropTime}}{{transport.departureDropTime}}{{else}}To Be Confirmed{{/if}}</span></div>
              <div class="kv"><span class="k">Vehicle</span><span class="sep">:</span><span class="v">{{#if transport.vehicleModel}}{{transport.vehicleModel}}{{else}}Private Transfer{{/if}}</span></div>
            </div>
          </div>
        </div>
      </div>
      {{/if}}

      <div class="cover-section">
        <div class="cover-section-title">Accommodation (On {{#if hotels.0.mealPlan}}{{titleCase hotels.0.mealPlan}}{{else}}Confirmed Basis{{/if}})</div>
        <table class="accommodation-table">
          <tbody>
            {{#each hotels}}
            <tr>
              <td class="night">{{this.nightNumber}} Night</td>
              <td>{{this.hotelName}}</td>
              <td>{{this.roomCategory}}</td>
              <td>{{#if this.mealPlan}}{{titleCase this.mealPlan}}{{else}}As Confirmed{{/if}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="page details-page">
    <div class="content">
      <div class="header">
        <div class="logo">VSL <span>360</span></div>
        <h1>Itinerary Story</h1>
        <p class="subtitle">Experience Sri Lanka Completely</p>
      </div>

      <div class="welcome">
        <h2>Dear {{client.name}},</h2>
        <p>Welcome to a {{booking.numberOfDays}}-day journey shaped with local character, thoughtful comfort, and meaningful moments.</p>
        <p>{{formatDate booking.arrivalDate}} - {{formatDate booking.departureDate}}</p>
      </div>

      <div class="pillar">
        <h3>Destination Discovery</h3>
        <div class="pillar-body">
          Your route has been curated to balance iconic scenery with quieter corners of Sri Lanka, creating a complete sense of place from arrival to departure.
        </div>
      </div>

      <div class="pillar">
        <h3>Travel Experiences</h3>
        <div class="pillar-body">
          Each transfer and activity is arranged to keep your days seamless, so you can focus on the experience itself rather than the logistics.
        </div>
      </div>

      {{#if transport}}
      <div class="day-card">
        <div class="day-header">Arrival Details</div>
        <div class="day-body">
          <div class="grid">
            <div class="detail"><span class="label">Pickup Location</span><div class="value">{{transport.arrivalPickupLocation}}</div></div>
            <div class="detail"><span class="label">Pickup Time</span><div class="value">{{transport.arrivalPickupTime}}</div></div>
            <div class="detail"><span class="label">Vehicle</span><div class="value">{{transport.vehicleModel}}</div></div>
            <div class="detail"><span class="label">Driver</span><div class="value">{{transport.driverName}} ({{transport.driverLanguage}})</div></div>
          </div>
        </div>
      </div>
      {{/if}}

      {{#each days}}
      <div class="day-card">
        <div class="day-header">Day {{this.dayNumber}}</div>
        <div class="day-body">
          <div class="grid">
            {{#if this.hotel}}
            <div class="detail"><span class="label">Hotel</span><div class="value">{{this.hotel.hotelName}}</div></div>
            <div class="detail"><span class="label">Room</span><div class="value">{{this.hotel.roomCategory}}</div></div>
            <div class="detail"><span class="label">Meal Plan</span><div class="value">{{this.hotel.mealPlan}}</div></div>
            {{#if this.hotel.mealPreference}}
            <div class="detail"><span class="label">Meal Preference</span><div class="value">{{this.hotel.mealPreference}}</div></div>
            {{/if}}
            {{/if}}
            {{#if this.transport}}
            <div class="detail"><span class="label">Activities</span><div class="value">{{this.transport.description}}</div></div>
            {{#if this.transport.pickupTime}}
            <div class="detail"><span class="label">Pickup</span><div class="value">{{this.transport.pickupTime}} - {{this.transport.pickupLocation}}</div></div>
            {{/if}}
            {{/if}}
          </div>
        </div>
      </div>
      {{/each}}

      <div class="pillar">
        <h3>Luxury Stays</h3>
        <div class="pillar-body">
          Your stays are selected for comfort, atmosphere, and location, so each evening feels like part of the journey, not just a stop between destinations.
        </div>
      </div>

      {{#if transport}}
      <div class="day-card">
        <div class="day-header">Departure Details</div>
        <div class="day-body">
          <div class="grid">
            <div class="detail"><span class="label">Drop-off Location</span><div class="value">{{transport.departureDropLocation}}</div></div>
            <div class="detail"><span class="label">Drop-off Time</span><div class="value">{{transport.departureDropTime}}</div></div>
          </div>
        </div>
      </div>
      {{/if}}

      {{#if booking.generalNotes}}
      <div class="notes-section">
        <h3>Important Notes</h3>
        <p>{{booking.generalNotes}}</p>
      </div>
      {{/if}}

      {{#if booking.specialCelebrations}}
      <div class="notes-section" style="margin-top: 12px;">
        <h3>Local Culture & Celebrations</h3>
        <p>{{booking.specialCelebrations}}</p>
      </div>
      {{/if}}

      <div class="pillar">
        <h3>Travel Moments</h3>
        <div class="pillar-body">
          Look out for candid moments in warm natural light: sunrise roads, tea-country air, coastal evenings, and conversations that make the island memorable.
        </div>
      </div>
    </div>

    <div class="footer">
      <div class="brand">VSL 360</div>
      <p>Curated Travel Experiences</p>
      <ul class="cta-list">
        <li>When you are ready, we would be delighted to design your next Sri Lankan chapter.</li>
        <li>Share your preferred dates, and we will craft another journey around your travel style.</li>
        <li>Let us know the moments you value most, and we will shape the itinerary around them.</li>
      </ul>
    </div>
  </div>
</body>
</html>
