<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { margin: 14mm 16mm; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Trebuchet MS', 'Lucida Sans', Arial, sans-serif;
      color: #3b3230;
      font-size: 12px;
      line-height: 1.55;
      background: #fff;
    }

    .page {
      display: flex;
      flex-direction: column;
      min-height: calc(297mm - 28mm);
    }
    .content { flex: 1; }

    /* ── Header ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 10px;
    }
    .logo img {
      max-height: 52px;
      max-width: 200px;
      object-fit: contain;
    }
    .logo-fallback {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 22px;
      font-weight: 700;
      color: #b08d57;
    }
    .company-info { text-align: right; }
    .company-name {
      font-weight: 700;
      font-size: 13px;
      color: #3b3230;
    }
    .company-detail {
      font-size: 11px;
      color: #555;
    }
    .header-line {
      border: none;
      border-top: 2.5px solid #b08d57;
      margin: 0 0 20px 0;
    }

    /* ── Greeting ── */
    .greeting {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 22px;
      font-weight: 700;
      color: #3b3230;
      margin-bottom: 8px;
    }
    .intro-text {
      font-size: 12px;
      color: #3b3230;
      margin-bottom: 20px;
      line-height: 1.6;
    }

    /* ── Tour Overview ── */
    .section-title {
      font-weight: 700;
      font-size: 14px;
      color: #3b3230;
      margin-bottom: 8px;
    }
    .tour-overview {
      margin-bottom: 22px;
    }
    .overview-grid {
      display: flex;
      gap: 14px;
      margin-top: 6px;
    }
    .overview-col {
      flex: 1;
    }
    .overview-group-title {
      font-weight: 700;
      font-size: 11px;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
      padding-bottom: 3px;
      border-bottom: 1px solid #e0dbd6;
    }
    .overview-row {
      display: flex;
      margin-bottom: 2px;
      font-size: 12px;
    }
    .overview-label {
      width: 120px;
      color: #777;
      flex-shrink: 0;
    }
    .overview-value {
      color: #3b3230;
      font-weight: 500;
    }

    /* ── Hotel Table ── */
    .hotel-table {
      width: 100%;
      border-collapse: collapse;
      margin: 0 0 20px 0;
      font-size: 11.5px;
    }
    .hotel-table thead th {
      background: #3b3230;
      color: #fff;
      padding: 9px 12px;
      text-align: center;
      font-weight: 600;
      font-size: 12px;
    }
    .hotel-table tbody td {
      padding: 8px 12px;
      text-align: center;
      border-bottom: 1px solid #e0dbd6;
      color: #3b3230;
    }
    .hotel-table tbody tr:nth-child(even) {
      background: #f9f7f5;
    }

    /* ── Note Section ── */
    .meal-note {
      margin-bottom: 18px;
    }
    .meal-note-label {
      font-weight: 700;
      font-size: 12px;
      color: #3b3230;
      margin-bottom: 4px;
    }
    .meal-note-text {
      font-size: 12px;
      color: #b08d57;
    }

    /* ── Closing ── */
    .closing-text {
      font-size: 12px;
      color: #3b3230;
      line-height: 1.6;
      margin-bottom: 20px;
      text-align: justify;
    }
    .sign-off {
      font-size: 12px;
      color: #3b3230;
      line-height: 1.7;
      margin-bottom: 12px;
    }
    .sign-off .name {
      font-weight: 700;
    }

    /* ── Computer Generated Note ── */
    .computer-generated-note {
      font-size: 10px;
      color: #888;
      font-style: italic;
      margin-top: 16px;
    }

    /* ── Footer ── */
    .footer { margin-top: auto; }
    .contact-bar {
      background: #8b6a42;
      color: #fff;
      padding: 12px 24px;
      display: flex;
      justify-content: space-around;
      align-items: center;
      border-radius: 6px;
      font-size: 11px;
      letter-spacing: 0.2px;
    }
    .contact-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* ── Compact mode ── */
    body.compact { font-size: 11px; line-height: 1.45; }
    body.compact .greeting { font-size: 19px; margin-bottom: 6px; }
    body.compact .intro-text { font-size: 11px; margin-bottom: 16px; }
    body.compact .section-title { font-size: 13px; margin-bottom: 6px; }
    body.compact .tour-overview { margin-bottom: 16px; }
    body.compact .overview-row { font-size: 11px; }
    body.compact .overview-grid { gap: 10px; }
    body.compact .overview-label { width: 100px; }
    body.compact .hotel-table { font-size: 10.5px; }
    body.compact .hotel-table thead th { padding: 7px 8px; font-size: 11px; }
    body.compact .hotel-table tbody td { padding: 6px 8px; }
    body.compact .meal-note { margin-bottom: 14px; }
    body.compact .closing-text { font-size: 11px; margin-bottom: 16px; }
    body.compact .sign-off { font-size: 11px; }
    body.compact .contact-bar { padding: 10px 18px; font-size: 10px; }
  </style>
</head>
<body class="{{layoutMode}}">
  <div class="page">
    <div class="content">

      <!-- Header -->
      <div class="header">
        <div class="logo">
          {{#if brandLogoImage}}
            <img src="{{brandLogoImage}}" alt="VSL 360" />
          {{else}}
            <div class="logo-fallback">VSL 360</div>
          {{/if}}
        </div>
        <div class="company-info">
          <div class="company-name">Visit Sri Lanka 360 (Pvt) Ltd</div>
          <div class="company-detail">1/111, De Mel Road, Moratuwa, 10400</div>
          <div class="company-detail">Business Registration No: PV 00330941</div>
        </div>
      </div>
      <hr class="header-line" />

      <!-- Greeting -->
      <div class="greeting">Dear {{client.name}}</div>
      <div class="intro-text">
        We are pleased to confirm your hotel bookings for your upcoming group tour in Sri Lanka. Below is your detailed hotel itinerary.
      </div>

      <!-- Tour Overview -->
      <div class="tour-overview">
        <div class="section-title">Tour Overview</div>
        <div class="overview-grid">
          <div class="overview-col">
            <div class="overview-group-title">Tour Details</div>
            <div class="overview-row">
              <div class="overview-label">Country</div>
              <div class="overview-value">: {{client.citizenship}}</div>
            </div>
            <div class="overview-row">
              <div class="overview-label">From</div>
              <div class="overview-value">: {{formatDate booking.arrivalDate}}</div>
            </div>
            <div class="overview-row">
              <div class="overview-label">To</div>
              <div class="overview-value">: {{formatDate booking.departureDate}}</div>
            </div>
            <div class="overview-row">
              <div class="overview-label">Guests</div>
              <div class="overview-value">: {{padZero totalGuests}} {{guestBreakdown adults children infants}}</div>
            </div>
            <div class="overview-row">
              <div class="overview-label">Meal Plan</div>
              <div class="overview-value">: {{mealPlanSummary hotels}}</div>
            </div>
            <div class="overview-row">
              <div class="overview-label">Rooms</div>
              <div class="overview-value">: {{roomSummary hotels}}</div>
            </div>
          </div>
          <div class="overview-col">
            <div class="overview-group-title">Transport</div>
            {{#if transport}}
            <div class="overview-row">
              <div class="overview-label">Vehicle</div>
              <div class="overview-value">: {{transport.vehicleModel}}</div>
            </div>
            {{#if transport.vehicleIdNumber}}
            <div class="overview-row">
              <div class="overview-label">Vehicle ID</div>
              <div class="overview-value">: {{transport.vehicleIdNumber}}</div>
            </div>
            {{/if}}
            <div class="overview-row">
              <div class="overview-label">Driver</div>
              <div class="overview-value">: {{transport.driverName}} ({{transport.driverLanguage}})</div>
            </div>
            {{else}}
            <div class="overview-row">
              <div class="overview-value" style="color:#888;">To Be Confirmed</div>
            </div>
            {{/if}}
          </div>
        </div>
      </div>

      <!-- Hotel Itinerary Table -->
      <table class="hotel-table">
        <thead>
          <tr>
            <th>Day</th>
            <th>Date</th>
            <th>Location</th>
            <th>Hotel Name</th>
            <th>Room Category</th>
          </tr>
        </thead>
        <tbody>
          {{#each days}}
          <tr>
            <td>{{this.dayNumber}}</td>
            <td>{{formatDate this.date}}</td>
            <td>{{this.location}}</td>
            <td>{{this.hotelName}}</td>
            <td>{{this.roomCategory}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <!-- Meal Plan Note -->
      <div class="meal-note">
        <div class="meal-note-label">Note:</div>
        <div class="meal-note-text">BB = Bed &amp; Breakfast&nbsp;&nbsp;&nbsp;&nbsp;HB = Half Board&nbsp;&nbsp;&nbsp;&nbsp;FB = Full Board, Room Only</div>
      </div>

      <!-- Closing -->
      <div class="closing-text">
        We look forward to welcoming you to Sri Lanka and ensuring a safe, comfortable, and memorable journey. Please do not hesitate to contact us if you need any further assistance.
      </div>

      <div class="sign-off">
        Warm regards,<br /><br />
        <span class="name">Pawara Soysa</span><br />
        Managing Director<br />
        Visit Sri Lanka 360
      </div>

      <div class="computer-generated-note">
        This is a computer generated document. Doesn't require a signature.
      </div>

    </div>

    <!-- Footer -->
    <div class="footer">
      <div class="contact-bar">
        <div class="contact-item">&#9742;&nbsp; Tel: +94727715854</div>
        <div class="contact-item">&#9993;&nbsp; Email: infovsl360@gmail.com</div>
        <div class="contact-item">&#127760;&nbsp; www.visitsrilanka360.com</div>
      </div>
    </div>
  </div>
</body>
</html>
