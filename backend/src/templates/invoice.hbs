<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { margin: 14mm 12mm; }
    :root {
      --ocean-blue: #204050;
      --tropical-green: #3d6b54;
      --sand-beige: #f0e0e0;
      --sunset-gold: #c08020;
      --paper: #f0f0f0;
      --ink: #1f2933;
      --muted: #6a7280;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Mundial', 'Helvetica Neue', Arial, sans-serif; color: var(--ink); font-size: 12.5px; line-height: 1.5; background: var(--paper); }
    .page {
      border: 1px solid #dde2ea;
      border-radius: 10px;
      padding: 18px;
      background: #f5f6f8;
      min-height: calc(297mm - 28mm);
      display: flex;
      flex-direction: column;
    }
    .content { flex: 1; }
    .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid var(--ocean-blue); padding-bottom: 14px; margin-bottom: 18px; }
    .logo { font-family: 'Alegros', Georgia, 'Times New Roman', serif; font-size: 28px; font-weight: 700; color: var(--ocean-blue); letter-spacing: 0.5px; }
    .logo span { color: var(--sunset-gold); }
    .invoice-title { font-family: 'Alegros', Georgia, serif; font-size: 30px; color: var(--ocean-blue); font-weight: 700; }
    .subtitle { color: var(--muted); font-size: 11px; margin-top: 3px; }
    .info-section { display: flex; justify-content: space-between; gap: 14px; margin-bottom: 12px; }
    .info-block { flex: 1; }
    .panel {
      background: #f9fafc;
      border: 1px solid #dbe1ea;
      border-radius: 8px;
      padding: 12px 14px;
    }
    .info-block h3 { color: var(--muted); font-size: 10.5px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .info-block p { margin-bottom: 4px; }
    .billto-card {
      background: linear-gradient(180deg, #fcfdff 0%, #f8fafd 100%);
      border-color: #d6deea;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.7);
    }
    .billto-card h3 {
      margin-bottom: 10px;
      letter-spacing: 1.1px;
    }
    .contact-stack {
      display: grid;
      gap: 5px;
    }
    .contact-line {
      color: #334155;
      line-height: 1.4;
      word-break: break-word;
    }
    .inline-label { color: var(--muted); font-weight: 600; margin-right: 4px; }
    .guest-name {
      font-size: 19px;
      font-weight: 700;
      color: var(--ocean-blue);
      margin-bottom: 8px;
      letter-spacing: 0.2px;
      line-height: 1.15;
    }
    .detail-row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 4px;
      border-bottom: 1px dashed #e3e7ee;
      padding-bottom: 4px;
    }
    .detail-row:last-child { margin-bottom: 0; border-bottom: 0; padding-bottom: 0; }
    .detail-row .label { color: var(--muted); font-weight: 600; }
    .tour-details {
      background: #f7f9fc;
      border: 1px solid #dbe1ea;
      border-left: 3px solid var(--ocean-blue);
      border-radius: 8px;
      padding: 10px 12px;
      margin-bottom: 14px;
    }
    table { width: 100%; border-collapse: collapse; margin: 14px 0; border: 1px solid #d6d9df; border-radius: 8px; overflow: hidden; }
    thead th { background: var(--ocean-blue); color: #fff; padding: 9px 12px; text-align: left; font-weight: 600; }
    tbody td { padding: 9px 12px; border-bottom: 1px solid #dde1e8; }
    tbody tr:nth-child(even) { background: #f6f7f9; }
    .total-row td { font-weight: 700; font-size: 14.5px; border-top: 2px solid var(--sunset-gold); background: #fff9ec; }
    .notes { background: #f7f0e3; border-left: 4px solid var(--sunset-gold); padding: 12px; border-radius: 8px; margin-top: 12px; }
    .notes h3 { font-family: 'Alegros', Georgia, serif; font-size: 14px; color: var(--ocean-blue); margin-bottom: 8px; }
    .footer { margin-top: auto; text-align: center; color: var(--muted); font-size: 11.5px; border-top: 1px solid #d9dce3; padding-top: 10px; }
    .tagline { color: var(--ocean-blue); font-weight: 600; margin-top: 4px; }

    /* Safe adaptive mode: mild compaction only for longer note content */
    body.compact { font-size: 12px; line-height: 1.42; }
    body.compact .page { padding: 15px; }
    body.compact .header { margin-bottom: 14px; padding-bottom: 11px; }
    body.compact .invoice-title { font-size: 28px; }
    body.compact .info-section { gap: 12px; margin-bottom: 10px; }
    body.compact .panel { padding: 10px 11px; }
    body.compact .guest-name { font-size: 17px; margin-bottom: 6px; }
    body.compact .contact-stack { gap: 4px; }
    body.compact .tour-details { padding: 9px 10px; margin-bottom: 11px; }
    body.compact table { margin: 10px 0; }
    body.compact thead th { padding: 8px 10px; }
    body.compact tbody td { padding: 8px 10px; }
    body.compact .notes { padding: 10px; margin-top: 10px; }
    body.compact .footer { margin-top: auto; padding-top: 8px; font-size: 11px; }
  </style>
</head>
<body class="{{layoutMode}}">
  <div class="page">
  <div class="content">
  <div class="header">
    <div class="logo">VSL <span>360</span></div>
    <div style="text-align:right;">
      <div class="invoice-title">INVOICE</div>
      <div class="subtitle">Curated Travel Experiences</div>
    </div>
  </div>

  <div class="info-section">
    <div class="info-block panel billto-card">
      <h3>Bill To</h3>
      <div class="contact-stack">
        <p class="guest-name">{{client.name}}</p>
        <p class="contact-line">{{client.email}}</p>
        <p class="contact-line">{{client.contactNumber}}</p>
        <p class="contact-line"><span class="inline-label">Citizenship:</span>{{titleCase client.citizenship}}</p>
      </div>
    </div>
    <div class="info-block panel">
      <h3>Invoice Details</h3>
      <div class="detail-row"><span class="label">Invoice #</span><strong>{{invoice.invoiceNumber}}</strong></div>
      <div class="detail-row"><span class="label">Date</span><strong>{{formatDate invoice.invoiceDate}}</strong></div>
      <div class="detail-row"><span class="label">Booking ID</span><strong>{{booking.bookingId}}</strong></div>
    </div>
  </div>

  <div class="info-block tour-details">
    <h3>Tour Details</h3>
    <p><strong>Duration:</strong> {{booking.numberOfDays}} Days</p>
    <p><strong>Travel Dates:</strong> {{formatDate booking.arrivalDate}} — {{formatDate booking.departureDate}}</p>
    <p><strong>Number of Guests:</strong> {{paxCount}}</p>
  </div>

  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th style="text-align: right;">Amount</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Cost per person</td>
        <td style="text-align: right;">{{formatCurrency invoice.costPerPerson}}</td>
      </tr>
      <tr>
        <td>Total ({{paxCount}} guests)</td>
        <td style="text-align: right;">{{formatCurrency invoice.totalAmount}}</td>
      </tr>
      <tr>
        <td>Advance Paid</td>
        <td style="text-align: right;">- {{formatCurrency invoice.advancePaid}}</td>
      </tr>
      <tr class="total-row">
        <td>Balance Due</td>
        <td style="text-align: right;">{{formatCurrency invoice.balanceAmount}}</td>
      </tr>
    </tbody>
  </table>

  {{#if invoice.paymentInstructions}}
  <div class="notes">
    <h3>Payment Instructions</h3>
    <p>{{invoice.paymentInstructions}}</p>
  </div>
  {{/if}}

  {{#if invoice.paymentNotes}}
  <div class="notes" style="margin-top: 12px;">
    <h3>Notes</h3>
    <p>{{invoice.paymentNotes}}</p>
  </div>
  {{/if}}
  </div>

  <div class="footer">
    <p>VSL 360 Tour Operations</p>
    <p class="tagline">Experience Sri Lanka Completely</p>
  </div>
  </div>
</body>
</html>
