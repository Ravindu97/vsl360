<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { margin: 12mm 14mm; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Trebuchet MS', 'Lucida Sans', Arial, sans-serif;
      color: #3b3230;
      font-size: 11.5px;
      line-height: 1.5;
      background: #fff;
    }
    .page {
      min-height: calc(297mm - 32mm);
      display: flex;
      flex-direction: column;
    }
    .content { flex: 1; }

    /* ── Header ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 10px;
      margin-bottom: 0;
    }
    .logo img {
      height: 52px;
      width: auto;
      object-fit: contain;
      display: block;
    }
    .logo-fallback {
      font-size: 26px;
      font-weight: 700;
      color: #3b3230;
    }
    .company-info {
      text-align: right;
      line-height: 1.5;
    }
    .company-name {
      font-weight: 700;
      font-size: 12.5px;
      color: #3b3230;
      margin-bottom: 2px;
    }
    .company-detail {
      font-size: 10.5px;
      color: #555;
    }
    .header-line {
      border: none;
      border-top: 2.5px solid #b08d57;
      margin: 0 0 18px 0;
    }

    /* ── Invoice title ── */
    h1.invoice-title {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 40px;
      font-weight: 700;
      color: #3b3230;
      letter-spacing: 1px;
      margin: 0 0 18px 0;
    }

    /* ── Billing row ── */
    .billing-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
    }
    .bill-to {}
    .bill-to-label {
      font-weight: 700;
      font-size: 13px;
      color: #3b3230;
      margin-bottom: 4px;
    }
    .bill-to-name {
      font-size: 12.5px;
      color: #3b3230;
      margin-bottom: 2px;
    }
    .bill-to-detail {
      font-size: 11px;
      color: #555;
      margin-bottom: 1px;
      line-height: 1.5;
    }
    .invoice-meta {
      text-align: right;
      font-size: 11.5px;
      color: #555;
      line-height: 1.65;
    }
    .invoice-meta strong {
      color: #3b3230;
    }

    /* ── Description ── */
    .desc-title {
      font-weight: 700;
      font-size: 15px;
      color: #3b3230;
      margin-bottom: 4px;
    }
    .desc-text {
      font-size: 11.5px;
      color: #3b3230;
      margin-bottom: 18px;
      line-height: 1.55;
    }

    /* ── Summary table ── */
    .summary-table {
      width: 100%;
      border-collapse: collapse;
      margin: 0 0 22px 0;
      font-size: 11px;
    }
    .summary-table th,
    .summary-table td {
      border: 1px solid #bbb;
      padding: 10px 8px;
      text-align: center;
      vertical-align: middle;
    }
    .summary-table thead th {
      font-weight: 700;
      font-size: 11px;
      color: #3b3230;
      background: #f5f5f4;
      line-height: 1.35;
    }
    .summary-table tbody td {
      font-size: 11.5px;
      color: #3b3230;
    }
    .summary-table tbody td.balance {
      font-weight: 700;
      font-size: 12.5px;
      color: #3b3230;
    }

    /* ── Tour Inclusions ── */
    .tour-include-title {
      font-weight: 700;
      font-size: 13.5px;
      color: #3b3230;
      margin-bottom: 6px;
    }
    .tour-include-list {
      margin: 0 0 20px 20px;
      padding: 0;
      font-size: 11.5px;
      color: #3b3230;
      line-height: 1.75;
    }
    .tour-include-list li {
      margin-bottom: 1px;
    }

    /* ── Payment Terms ── */
    .payment-terms {
      border: 1.5px solid #999;
      border-radius: 12px;
      padding: 14px 16px;
      margin-bottom: 0;
    }
    .payment-terms-title {
      font-weight: 700;
      font-size: 14px;
      color: #3b3230;
      margin-bottom: 8px;
    }
    .payment-terms-text {
      font-size: 11.5px;
      color: #555;
      line-height: 1.65;
    }

    /* ── Computer Generated Note ── */
    .computer-generated-note {
      font-size: 10px;
      color: #888;
      font-style: italic;
      margin-top: 16px;
    }

    /* ── Footer ── */
    .footer { margin-top: auto; }
    .footer-thanks {
      text-align: center;
      padding: 18px 0 10px;
    }
    .footer-thanks .main {
      font-weight: 700;
      font-size: 14px;
      color: #3b3230;
    }
    .footer-thanks .sub {
      font-size: 12px;
      font-style: italic;
      margin-top: 4px;
      color: #555;
    }
    .contact-bar {
      background: #8b6a42;
      color: #fff;
      padding: 12px 24px;
      display: flex;
      justify-content: space-around;
      align-items: center;
      border-radius: 6px;
      font-size: 11px;
      letter-spacing: 0.2px;
    }
    .contact-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* ── Compact mode ── */
    body.compact { font-size: 11px; }
    body.compact h1.invoice-title { font-size: 34px; margin-bottom: 14px; }
    body.compact .billing-row { margin-bottom: 16px; }
    body.compact .desc-text { margin-bottom: 14px; }
    body.compact .summary-table { margin-bottom: 18px; }
    body.compact .summary-table th,
    body.compact .summary-table td { padding: 7px 5px; }
    body.compact .tour-include-list { margin-bottom: 16px; }
    body.compact .payment-terms { padding: 11px 13px; }
    body.compact .footer-thanks { padding: 14px 0 8px; }
  </style>
</head>
<body class="{{layoutMode}}">
  <div class="page">
    <div class="content">

      <!-- Header -->
      <div class="header">
        <div class="logo">
          {{#if brandLogoImage}}
            <img src="{{brandLogoImage}}" alt="VSL 360" />
          {{else}}
            <div class="logo-fallback">VSL 360</div>
          {{/if}}
        </div>
        <div class="company-info">
          <div class="company-name">Visit Sri Lanka 360 (Pvt) Ltd</div>
          <div class="company-detail">1/111, De Mel Road, Moratuwa, 10400</div>
          <div class="company-detail">Business Registration No: PV 00330941</div>
        </div>
      </div>
      <hr class="header-line" />

      <!-- Invoice title -->
      <h1 class="invoice-title">INVOICE</h1>

      <!-- Billed To + Invoice meta -->
      <div class="billing-row">
        <div class="bill-to">
          <p class="bill-to-label">Billed To:</p>
          <p class="bill-to-name">{{client.name}}</p>
          {{#if client.contactNumber}}<p class="bill-to-detail">Phone: {{client.contactNumber}}</p>{{/if}}
          {{#if client.email}}<p class="bill-to-detail">{{client.email}}</p>{{/if}}
        </div>
        <div class="invoice-meta">
          <p>Invoice No: <strong>{{invoice.invoiceNumber}}</strong></p>
          <p>Date: <strong>{{formatDate invoice.invoiceDate}}</strong></p>
          <p>Booking ID: <strong>{{booking.bookingId}}</strong></p>
        </div>
      </div>

      <!-- Description -->
      <div class="desc-title">Description</div>
      <div class="desc-text">{{#if invoice.paymentNotes}}{{invoice.paymentNotes}}{{else}}Advance payment for upcoming {{booking.numberOfDays}} Days tour in Sri Lanka{{/if}}</div>

      <!-- Summary table -->
      <table class="summary-table">
        <thead>
          <tr>
            <th>Arrival<br>Date</th>
            <th>Departure<br>Date</th>
            <th>NO. Of<br>Guests</th>
            <th>Cost Per<br>Person</th>
            <th>Total<br>Amount</th>
            <th>Advance<br>Paid</th>
            <th>Balance<br>Due</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>{{formatDate booking.arrivalDate}}</td>
            <td>{{formatDate booking.departureDate}}</td>
            <td>{{paxCount}}</td>
            <td>{{formatCurrency invoice.costPerPerson}}</td>
            <td>{{formatCurrency invoice.totalAmount}}</td>
            <td>{{formatCurrency invoice.advancePaid}}</td>
            <td class="balance">{{formatCurrency invoice.balanceAmount}}</td>
          </tr>
        </tbody>
      </table>

      <!-- Tour Inclusions -->
      {{#if tourInclusionsList.length}}
      <div class="tour-include-title">Tour Include:</div>
      <ul class="tour-include-list">
        {{#each tourInclusionsList}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
      {{/if}}

      <!-- Payment Terms -->
      <div class="payment-terms">
        <div class="payment-terms-title">Payment Terms</div>
        <div class="payment-terms-text">{{#if invoice.paymentInstructions}}{{invoice.paymentInstructions}}{{else}}The total amount must be settled in either U.S. Dollars (USD), UPI Global transfer or credit or debit card payment to the company bank account upon arrival at Katunayake Airport Colombo on the day of your arrival.{{/if}}</div>
      </div>

      <div class="computer-generated-note">
        This is a computer generated document. Doesn't require a signature.
      </div>

    </div>

    <!-- Footer -->
    <div class="footer">
      <div class="footer-thanks">
        <p class="main">Thank you for choosing VSL 360 Pvt Ltd</p>
        <p class="sub">For any inquiries or clarifications, feel free to contact us.</p>
      </div>
      <div class="contact-bar">
        <div class="contact-item">&#9742;&nbsp; Tel: +94727715854</div>
        <div class="contact-item">&#9993;&nbsp; Email: infovsl360@gmail.com</div>
        <div class="contact-item">&#127760;&nbsp; www.visitsrilanka360.com</div>
      </div>
    </div>
  </div>
</body>
</html>
